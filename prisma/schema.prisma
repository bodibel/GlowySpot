// Nudge for type regeneration
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum SubscriptionPlan {
  FREE
  STANDARD
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE     // fizetett vagy ingyenes, még érvényes
  INACTIVE   // lejárt free vagy lemondott
  PAST_DUE   // fizetés sikertelen
  CANCELLED  // lemondott, de még fut az időszak végéig
}

// ─── NextAuth Models ──────────────────────────────────────────────────────────

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("visitor") // visitor, provider, admin
  accounts      Account[]
  sessions      Session[]
  salons        Salon[]
  bookings      Booking[]
  reviews       Review[]
  messagesSent  Message[] @relation("SentMessages")
  messagesReceived Message[] @relation("ReceivedMessages")
  comments      Comment[]
  likes         Like[]
  favorites     Favorite[]
  isActive      Boolean   @default(true)
  inactivatedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Salon ────────────────────────────────────────────────────────────────────

model Salon {
  id            String   @id @default(cuid())
  name          String
  country       String   @default("Magyarország")
  city          String
  district      String?
  street        String?
  houseNumber   String?
  floor         String?
  door          String?
  zipCode       String?
  address       String
  categories    String[]
  currency      String   @default("HUF")
  description   String?  @db.Text
  rating        Float    @default(0)
  reviewCount   Int      @default(0)
  images        String[]
  profileImage  String?
  coverImage    String?
  email         String?
  phone         String?
  website       String?
  ownerId       String
  owner         User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  services      Service[]
  openingHours  OpeningHour[]
  closedDates   ClosedDate[]
  posts         Post[]
  bookings      Booking[]
  reviews       Review[]
  favorites     Favorite[]
  languages     String[]
  lat           Float?
  lng           Float?
  isActive      Boolean   @default(true)
  inactivatedAt DateTime?

  // Duplikáció megelőzés: normalizált telefon+cím hash, globálisan egyedi
  // Formátum: sha256(normalizedPhone + "|" + normalizedAddress)
  salonFingerprint String? @unique

  // Előfizetés (1-1 kapcsolat)
  subscription  Subscription?

  // Owner/About
  ownerName     String?
  ownerImage    String?
  aboutMe       String?  @db.Text
  isTeam        Boolean  @default(false)
  teamMembers   TeamMember[]

  // Contact preferences
  allowMessages       Boolean  @default(true)
  allowBookings       Boolean  @default(true)

  // Profile display settings
  showPhoneOnProfile  Boolean  @default(true)
  showEmailOnProfile  Boolean  @default(false)

  // Email notifications
  notifyNewMessage    Boolean  @default(true)
  notifyNewBooking    Boolean  @default(true)
  notifyNewReview     Boolean  @default(true)
  notifyNewFavorite   Boolean  @default(false)
  notifyPostLike      Boolean  @default(false)
  notifyPostComment   Boolean  @default(true)
  notifyWeeklyStats   Boolean  @default(true)
  notifyMonthlyStats  Boolean  @default(true)

  messages            Message[]
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// ─── Subscription ─────────────────────────────────────────────────────────────

model Subscription {
  id      String @id @default(cuid())
  salonId String @unique
  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)

  plan    SubscriptionPlan   @default(FREE)
  status  SubscriptionStatus @default(ACTIVE)

  // Pénznem (regisztrációkor meghatározva, ország alapján)
  billingCurrency String @default("HUF") // "HUF" | "EUR"

  // Stripe azonosítók (null amíg nincs fizetés)
  stripeCustomerId     String?
  stripeSubscriptionId String? @unique
  stripePriceId        String?

  // Aktuális számlázási időszak (Stripe szinkronizálva)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?

  // Free csomag lejárat (freeStartedAt + SubscriptionConfig.freeTrialDays)
  freeStartedAt DateTime  @default(now())
  freeExpiresAt DateTime?

  // 30 napos gördülő poszt számláló
  postWindowStart   DateTime @default(now())
  postCountInWindow Int      @default(0)

  // Ütemezett csomag visszaminősítés (időszak végén lép életbe)
  scheduledPlan   SubscriptionPlan?
  scheduledPlanAt DateTime?

  cancelAtPeriodEnd Boolean   @default(false)
  cancelledAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── SubscriptionConfig (admin által konfigurálható) ─────────────────────────

model SubscriptionConfig {
  id   String @id @default(cuid())

  // Free csomag korlátok
  freeTrialDays        Int @default(60)  // 2 hónap
  freeMonthlyPostLimit Int @default(5)

  // Stripe Price ID-k (admin adja meg)
  standardPriceHufId String?
  standardPriceEurId String?
  premiumPriceHufId  String?
  premiumPriceEurId  String?

  // Stripe kulcsok (admin adja meg a dashboardon)
  stripePublishableKey String?
  stripeSecretKey      String?  // Titkosítva tárolva
  stripeWebhookSecret  String?

  updatedAt DateTime @updatedAt
  updatedBy String?  // admin userId
}

// ─── TeamMember ───────────────────────────────────────────────────────────────

model TeamMember {
  id          String   @id @default(cuid())
  name        String
  role        String?
  description String?  @db.Text
  image       String?
  order       Int      @default(0)
  salonId     String
  salon       Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Service ──────────────────────────────────────────────────────────────────

model Service {
  id          String  @id @default(cuid())
  name        String
  price       String
  duration    String
  description String? @db.Text
  salonId     String
  salon       Salon   @relation(fields: [salonId], references: [id], onDelete: Cascade)
  bookings    Booking[]
}

// ─── OpeningHour / ClosedDate ─────────────────────────────────────────────────

model OpeningHour {
  id      String  @id @default(cuid())
  day     String
  open    String?
  close   String?
  isOpen  Boolean @default(true)
  salonId String
  salon   Salon   @relation(fields: [salonId], references: [id], onDelete: Cascade)
}

model ClosedDate {
  id      String @id @default(cuid())
  date    String
  reason  String
  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)
}

// ─── Post ─────────────────────────────────────────────────────────────────────

model Post {
  id        String   @id @default(cuid())
  content   String   @db.Text
  images    String[]
  videos    String[] // Standard+ csomagtól engedélyezett
  layout    String   @default("grid") // grid, carousel, collage, columns
  salonId   String
  salon     Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  comments  Comment[]
  likes     Like[]
  isActive      Boolean   @default(true)
  inactivatedAt DateTime?
  createdAt DateTime @default(now())
}

// ─── Booking ──────────────────────────────────────────────────────────────────

model Booking {
  id        String   @id @default(cuid())
  date      DateTime
  time      String
  status    String   @default("pending") // pending, confirmed, cancelled, completed
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  salonId   String
  salon     Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// ─── Review ───────────────────────────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String   @db.Text
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  salonId   String
  salon     Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// ─── Message ──────────────────────────────────────────────────────────────────

model Message {
  id         String   @id @default(cuid())
  subject    String?
  content    String   @db.Text
  senderId   String
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  salonId    String?
  salon      Salon?   @relation(fields: [salonId], references: [id], onDelete: SetNull)
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
}

// ─── Comment / Like / Favorite ────────────────────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Like {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Favorite {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@unique([userId, salonId])
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

// ─── Category ─────────────────────────────────────────────────────────────────

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  icon      String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
