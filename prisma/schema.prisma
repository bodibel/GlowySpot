// Nudge for type regeneration
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth Models
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("visitor") // visitor, provider, admin
  accounts      Account[]
  sessions      Session[]
  salons        Salon[]
  bookings      Booking[]
  reviews       Review[]
  messagesSent  Message[] @relation("SentMessages")
  messagesReceived Message[] @relation("ReceivedMessages")
  comments      Comment[]
  likes         Like[]
  favorites     Favorite[]
  isActive      Boolean   @default(true)
  inactivatedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Application Models
model Salon {
  id            String   @id @default(cuid())
  name          String
  country       String   @default("Magyarország")
  city          String
  district      String?
  street        String?
  houseNumber   String?
  floor         String?
  door          String?
  zipCode       String?
  address       String   // Keep full address for backward compatibility/display
  categories    String[]
  currency      String   @default("HUF")
  description   String?  @db.Text
  rating        Float    @default(0)
  reviewCount   Int      @default(0)
  images        String[]
  profileImage  String?
  coverImage    String?
  email         String?
  phone         String?
  website       String?
  ownerId       String
  owner         User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  services      Service[]
  openingHours  OpeningHour[]
  closedDates   ClosedDate[]
  posts         Post[]
  bookings      Booking[]
  reviews       Review[]
  favorites     Favorite[]
  languages     String[] // e.g. ["English", "Hungarian"]
  lat           Float?
  lng           Float?
  isActive      Boolean   @default(true)
  inactivatedAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  // Owner/About fields
  ownerName     String?
  ownerImage    String?
  aboutMe       String?  @db.Text
  isTeam        Boolean  @default(false)
  teamMembers   TeamMember[]
  // Contact preferences
  allowMessages       Boolean  @default(true)
  allowBookings       Boolean  @default(true)
  // Profile display settings
  showPhoneOnProfile  Boolean  @default(true)
  showEmailOnProfile  Boolean  @default(false)
  // Email notification preferences (granular)
  notifyNewMessage    Boolean  @default(true)
  notifyNewBooking    Boolean  @default(true)
  notifyNewReview     Boolean  @default(true)
  notifyNewFavorite   Boolean  @default(false)
  notifyPostLike      Boolean  @default(false)
  notifyPostComment   Boolean  @default(true)
  notifyWeeklyStats   Boolean  @default(true)
  notifyMonthlyStats  Boolean  @default(true)
  messages            Message[]
}

model TeamMember {
  id          String   @id @default(cuid())
  name        String
  role        String?
  description String?  @db.Text
  image       String?
  order       Int      @default(0)
  salonId     String
  salon       Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Service {
  id        String @id @default(cuid())
  name      String
  price     String
  duration  String
  description String? @db.Text
  salonId   String
  salon     Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)
  bookings  Booking[]
}

model OpeningHour {
  id        String   @id @default(cuid())
  day       String
  open      String?
  close     String?
  isOpen    Boolean  @default(true)
  salonId   String
  salon     Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
}

model ClosedDate {
  id        String @id @default(cuid())
  date      String
  reason    String
  salonId   String
  salon     Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)
}

model Post {
  id        String   @id @default(cuid())
  content   String   @db.Text
  images    String[]
  layout    String   @default("grid") // grid, carousel, collage, columns
  salonId   String
  salon     Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  comments  Comment[]
  likes     Like[]
  isActive  Boolean   @default(true)
  inactivatedAt DateTime?
  createdAt DateTime @default(now())
}

model Booking {
  id        String   @id @default(cuid())
  date      DateTime
  time      String
  status    String   @default("pending") // pending, confirmed, cancelled, completed
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  salonId   String
  salon     Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String   @db.Text
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  salonId   String
  salon     Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Message {
  id          String   @id @default(cuid())
  subject     String?
  content     String   @db.Text
  senderId    String
  sender      User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId  String
  receiver    User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  salonId     String?
  salon       Salon?   @relation(fields: [salonId], references: [id], onDelete: SetNull)
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Favorite {
  id        String @id @default(cuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  salonId   String
  salon     Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@unique([userId, salonId])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  icon      String?  // Name of the icon (e.g., "Scissors")
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
